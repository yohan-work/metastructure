{
  "name": "astryx-ui-kit",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "dev": "pnpm --filter playground-next dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "astryx": "node scripts/print-astryx-info.mjs",
    "astryx:components": "node scripts/print-astryx-info.mjs components",
    "astryx:tokens": "node scripts/print-astryx-info.mjs tokens",
